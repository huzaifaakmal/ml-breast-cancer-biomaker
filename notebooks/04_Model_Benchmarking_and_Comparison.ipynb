{
 "cells": [
  {
   "cell_type": "markdown",
   "id": "bench_intro",
   "metadata": {},
   "source": [
    "# 04. Model Benchmarking and Comparison\n",
    "This notebook compares our optimized SVM against other standard machine learning algorithms. \n",
    "**Revision Updates:**\n",
    "1. **Leakage Fix:** Feature selection is now nested within cross-validation using Pipelines.\n",
    "2. **Clinical Utility:** Added Decision Curve Analysis (DCA).\n",
    "3. **Specificity Optimization:** Added threshold analysis for clinical triage."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bench_setup",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import os\n",
    "from sklearn.svm import SVC\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "from sklearn.metrics import roc_auc_score, accuracy_score, f1_score, confusion_matrix, roc_curve\n",
    "from sklearn.feature_selection import SelectKBest, f_classif\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.pipeline import Pipeline\n",
    "from sklearn.model_selection import cross_val_score, StratifiedKFold\n",
    "\n",
    "RANDOM_STATE = 42\n",
    "np.random.seed(RANDOM_STATE)\n",
    "\n",
    "def process_geo_data(matrix_file, annotation_file, data_dir=\"../raw_data\"):\n",
    "    m_path = os.path.join(data_dir, matrix_file)\n",
    "    a_path = os.path.join(data_dir, annotation_file)\n",
    "    expr = pd.read_csv(m_path, sep=\"\\t\", comment=\"!\", low_memory=False)\n",
    "    expr.iloc[:, 1:] = expr.iloc[:, 1:].apply(pd.to_numeric, errors=\"coerce\")\n",
    "    gpl = pd.read_csv(a_path, sep=\"\\t\", comment=\"#\", low_memory=False)\n",
    "    gpl_clean = gpl[[\"ID\", \"Gene Symbol\"]].dropna()\n",
    "    gpl_clean = gpl_clean[gpl_clean[\"Gene Symbol\"] != \"---\"]\n",
    "    merged = expr.merge(gpl_clean, left_on=\"ID_REF\", right_on=\"ID\")\n",
    "    merged[\"Gene Symbol\"] = merged[\"Gene Symbol\"].astype(str).str.split(\"///\").str[0].str.strip()\n",
    "    gene_expr = merged.groupby(\"Gene Symbol\").mean(numeric_only=True)\n",
    "    return gene_expr.T\n",
    "\n",
    "def get_benchmarking_data():\n",
    "    X_train_raw = process_geo_data(\"GSE42568_series_matrix.txt\", \"GPL570-55999.txt\")\n",
    "    X_test_raw = process_geo_data(\"GSE15852_series_matrix.txt\", \"GPL96-57554.txt\")\n",
    "    y_train = np.array([1]*104 + [0]*17)\n",
    "    y_test = np.array([1]*43 + [0]*43)\n",
    "    common = X_train_raw.columns.intersection(X_test_raw.columns)\n",
    "    return X_train_raw[common], y_train, X_test_raw[common], y_test\n",
    "\n",
    "X_train, y_train, X_test, y_test = get_benchmarking_data()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "run_bench",
   "metadata": {},
   "source": [
    "### Compare Models (With Nested Feature Selection)\n",
    "We use Pipelines to ensure feature selection is performed within each CV fold, preventing leakage."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "execute_bench",
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_pipeline(clf):\n",
    "    return Pipeline([\n",
    "        ('scaler', StandardScaler()),\n",
    "        ('selector', SelectKBest(score_func=f_classif, k=500)),\n",
    "        ('classifier', clf)\n",
    "    ])\n",
    "\n",
    "models = {\\n",\n    "    'SVM (Linear)': create_pipeline(SVC(kernel='linear', class_weight='balanced', probability=True, random_state=RANDOM_STATE)),\\n",\n    "    'SVM (RBF)': create_pipeline(SVC(kernel='rbf', class_weight='balanced', probability=True, random_state=RANDOM_STATE)),\\n",\n    "    'SVM (Poly, d=3)': create_pipeline(SVC(kernel='poly', degree=3, class_weight='balanced', probability=True, random_state=RANDOM_STATE)),\\n",\n    "    'SVM (Sigmoid)': create_pipeline(SVC(kernel='sigmoid', class_weight='balanced', probability=True, random_state=RANDOM_STATE)),\\n",\n    "    'Random Forest': create_pipeline(RandomForestClassifier(n_estimators=100, class_weight='balanced', random_state=RANDOM_STATE)),\\n",\n    "    'Logistic Regression': create_pipeline(LogisticRegression(class_weight='balanced', max_iter=1000, random_state=RANDOM_STATE))\\n",\n    "}\\n",
    "\n",
    "results = []\n",
    "for name, model in models.items():\n",
    "    # Internal CV\n",
    "    cv_scores = cross_val_score(model, X_train, y_train, cv=StratifiedKFold(5), scoring='roc_auc')\n",
    "    \n",
    "    # External Validation\n",
    "    model.fit(X_train, y_train)\n",
    "    y_prob = model.predict_proba(X_test)[:, 1]\n",
    "    y_pred = model.predict(X_test)\n",
    "    \n",
    "    results.append({\n",
    "        'Model': name,\n",
    "        'CV ROC-AUC': cv_scores.mean(),\n",
    "        'External ROC-AUC': roc_auc_score(y_test, y_prob),\n",
    "        'Accuracy': accuracy_score(y_test, y_pred)\n",
    "    })\n",
    "\n",
    "comparison_df = pd.DataFrame(results)\n",
    "print(\"=== Robust Model Benchmarking Results ===\")\n",
    "print(comparison_df.to_string(index=False))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "dca_section",
   "metadata": {},
   "source": [
    "### Decision Curve Analysis (DCA)\n",
    "DCA evaluates the clinical \"Net Benefit\" of using the model compared to \"Treat All\" or \"Treat None\" strategies."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dca_impl",
   "metadata": {},
   "outputs": [],
   "source": [
    "def calculate_net_benefit(y_true, y_probs, thresholds):\n",
    "    net_benefits = []\n",
    "    for t in thresholds:\n",
    "        if t == 0:\n",
    "            # Treat All\n",
    "            tp = np.sum(y_true == 1)\n",
    "            fp = np.sum(y_true == 0)\n",
    "            nb = (tp / len(y_true))\n",
    "        elif t == 1:\n",
    "            nb = 0\n",
    "        else:\n",
    "            tp = np.sum((y_probs >= t) & (y_true == 1))\n",
    "            fp = np.sum((y_probs >= t) & (y_true == 0))\n",
    "            n = len(y_true)\n",
    "            nb = (tp / n) - (fp / n) * (t / (1 - t))\n",
    "        net_benefits.append(nb)\n",
    "    return net_benefits\n",
    "\n",
    "thresholds = np.linspace(0, 0.99, 100)\n",
    "y_probs_svm = models['SVM (Linear)'].predict_proba(X_test)[:, 1]\n",
    "\n",
    "import shap\\n",\n    "import os\\n",\n    "\\n",\n    "# 1. SHAP Analysis for SVM Interpretability\\n",\n    "def run_shap_analysis(model, X_train, X_test):\\n",\n    "    # For linear SVM, we can use LinearExplainer or KernelExplainer\\n",\n    "    # SVM Pipeline has scaling and selection steps\\n",\n    "    X_train_transformed = model.named_steps['scaler'].transform(X_train)\\n",\n    "    X_train_transformed = model.named_steps['selector'].transform(X_train_transformed)\\n",\n    "    \\n",\n    "    X_test_transformed = model.named_steps['scaler'].transform(X_test)\\n",\n    "    X_test_transformed = model.named_steps['selector'].transform(X_test_transformed)\\n",\n    "    \\n",\n    "    # Get selected feature names\\n",\n    "    mask = model.named_steps['selector'].get_support()\\n",\n    "    feature_names = X_train.columns[mask]\\n",\n    "    \\n",\n    "    explainer = shap.KernelExplainer(model.named_steps['classifier'].predict_proba, X_train_transformed[:50])\\n",\n    "    shap_values = explainer.shap_values(X_test_transformed[:50])\\n",\n    "    \\n",\n    "    plt.figure()\\n",\n    "    shap.summary_plot(shap_values[1], X_test_transformed[:50], feature_names=feature_names, show=False)\\n",\n    "    plt.title(\"SHAP Feature Importance (SVM Pipeline)\")\\n",\n    \"    plt.savefig(\\\"../figures/Figure_11_SHAP_Summary_Plot.jpeg\\\", dpi=300, bbox_inches='tight')\\n\",\n    "    plt.show()\\n",\n    "\\n",\n    "run_shap_analysis(models['SVM (Linear)'], X_train, X_test)\\n",\n    "\\n",\n    "# 2. Decision Curve Analysis with Confidence Intervals\\n",\n    "def calculate_net_benefit_ci(y_true, y_probs, thresholds, n_bootstraps=100):\\n",\n    "    all_nb = []\\n",\n    "    rng = np.random.RandomState(42)\\n",\n    "    for i in range(n_bootstraps):\\n",\n    "        indices = rng.randint(0, len(y_true), len(y_true))\\n",\n    "        if len(np.unique(y_true[indices])) < 2: continue\\n",\n    "        nb = calculate_net_benefit(y_true[indices], y_probs[indices], thresholds)\\n",\n    "        all_nb.append(nb)\\n",\n    "    \\n",\n    "    all_nb = np.array(all_nb)\\n",\n    "    mean_nb = np.mean(all_nb, axis=0)\\n",\n    "    lower_nb = np.percentile(all_nb, 2.5, axis=0)\\n",\n    "    upper_nb = np.percentile(all_nb, 97.5, axis=0)\\n",\n    "    return mean_nb, lower_nb, upper_nb\\n",\n    "\\n",\n    \"mean_nb, lower_nb, upper_nb = calculate_net_benefit_ci(y_test, y_probs_svm, thresholds)\\n\",\n    \"\\n\",\n    \"# Calculate Treat All and Treat None for the full set\\n\",\n    \"nb_all = calculate_net_benefit(y_test, np.ones(len(y_test)), thresholds)\\n\",\n    \"nb_none = calculate_net_benefit(y_test, np.zeros(len(y_test)), thresholds)\\n\",\n    \"\\n\",\n    \"plt.figure(figsize=(10, 6))\\n\",\n    \"plt.plot(thresholds, mean_nb, label='SVM Pipeline (Mean NB)', color='blue', lw=2)\\n\",\n    \"plt.fill_between(thresholds, lower_nb, upper_nb, color='blue', alpha=0.2, label='95% CI')\\n\",\n    \"plt.plot(thresholds, nb_all, label='Treat All', color='gray', linestyle='--')\\n\",\n    \"plt.plot(thresholds, nb_none, label='Treat None', color='black', lw=1)\\n\",\n    \"plt.ylim(-0.05, 0.6)\\n\",\n    \"plt.xlabel(\\\"Threshold Probability\\\")\\n\",\n    \"plt.ylabel(\\\"Net Benefit\\\")\\n\",\n    \"plt.title(\\\"DCA with 95% Confidence Intervals\\\")\\n\",\n    \"plt.legend()\\n\",\n    \"plt.grid(alpha=0.3)\\n\",\n    \"plt.savefig(\\\"../figures/Figure_9_Decision_Curve_Analysis.jpeg\\\", dpi=300)\\n\",\n    \"plt.show()\"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "threshold_opt",
   "metadata": {},
   "source": [
    "### Specificity Optimization\n",
    "To address the low specificity (55.8%), we identify a threshold that prioritizes high specificity (e.g., >90%) for clinical triage."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "threshold_impl",
   "metadata": {},
   "outputs": [],
   "source": [
    "fpr, tpr, thresholds_roc = roc_curve(y_test, y_probs_svm)\n",
    "spec = 1 - fpr\n",
    "\n",
    "# Find threshold for Specificity >= 0.90\n",
    "idx = np.where(spec >= 0.90)[0]\n",
    "if len(idx) > 0:\n",
    "    best_idx = idx[-1] # Highest TPR for Spec >= 0.90\n",
    "    print(f\"--- High-Specificity Operating Point ---\")\n",
    "    print(f\"Threshold: {thresholds_roc[best_idx]:.4f}\")\n",
    "    print(f\"Sensitivity (TPR): {tpr[best_idx]:.4f}\")\n",
    "    print(f\"Specificity (TNR): {spec[best_idx]:.4f}\")\n",
    "else:\n",
    "    print(\"Could not find threshold for Spec >= 0.90\")\n",
    "\n",
    "plt.figure(figsize=(8, 6))\n",
    "plt.plot(thresholds_roc, spec, label='Specificity', color='green')\n",
    "plt.plot(thresholds_roc, tpr, label='Sensitivity', color='red')\n",
    "plt.axhline(0.9, color='gray', linestyle='--', label='90% Target')\n",
    "plt.xlim(0, 1)\n",
    "plt.xlabel(\"Threshold\")\n",
    "plt.ylabel(\"Metric Score\")\n",
    "plt.title(\"Sensitivity vs. Specificity Trade-off\")\n",
    "plt.legend()\n",
    "plt.show()"
   ]
  }
 ],
